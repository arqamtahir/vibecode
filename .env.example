# Resend API key — used ONLY by /app/api/contact/route.ts to send contact emails.
RESEND_API_KEY=
# Inbox that receives contact-form submissions.
CONTACT_TO_EMAIL=
# Verified Resend sender address the contact emails are sent from.
CONTACT_FROM_EMAIL=
# Google Analytics measurement ID (public, client-side). Leave blank to disable analytics.
NEXT_PUBLIC_GA_ID=
